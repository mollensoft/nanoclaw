# NanoClaw environment configuration
# Copy this file to .env and fill in your values.

# ── OneCLI (credential proxy) ────────────────────────────────────────────────
ONECLI_URL=http://127.0.0.1:10254

# ── Timezone ─────────────────────────────────────────────────────────────────
TZ=America/New_York

# ── XMPP channel ─────────────────────────────────────────────────────────────
XMPP_JID=bot@your-xmpp-server.example       # required — bot's full JID
XMPP_PASSWORD=                              # required — bot account password
XMPP_RESOURCE=nanoclaw                      # optional — XMPP resource (default: nanoclaw)

# ── WhatsApp channel (add-whatsapp skill) ────────────────────────────────────
# No env vars required — auth state is stored in store/auth/

# ── Telegram channel (add-telegram skill) ────────────────────────────────────
# TELEGRAM_BOT_TOKEN=

# ── Slack channel (add-slack skill) ──────────────────────────────────────────
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# ── Discord channel (add-discord skill) ──────────────────────────────────────
# DISCORD_BOT_TOKEN=
